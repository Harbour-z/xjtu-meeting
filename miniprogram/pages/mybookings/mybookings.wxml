<!-- pages/mybookings/mybookings.wxml - 我的预约 -->
<wxs module="statusUtils">
module.exports = {
  getStatus: function(booking, currentDate, currentTime) {
    // 预约日期在当前日期之后 -> 待进行
    if (booking.date > currentDate) {
      return 'pending'
    }
    // 预约日期在当前日期之前 -> 已结束
    if (booking.date < currentDate) {
      return 'ended'
    }
    // 同一天，比较时间
    if (booking.start_time > currentTime) {
      return 'pending'
    } else if (booking.end_time <= currentTime) {
      return 'ended'
    } else {
      return 'ongoing'
    }
  },
  getStatusText: function(status) {
    if (status === 'pending') return '待进行'
    if (status === 'ongoing') return '进行中'
    if (status === 'ended') return '已结束'
    return ''
  },
  getStatusClass: function(status) {
    if (status === 'pending') return 'status-pending'
    if (status === 'ongoing') return 'status-ongoing'
    if (status === 'ended') return 'status-ended'
    return ''
  },
  canCancel: function(booking, currentDate, currentTime) {
    // 已结束的不能取消
    if (booking.date < currentDate) return false
    if (booking.date === currentDate && booking.end_time <= currentTime) return false
    return true
  }
}
</wxs>

<view class="page">
  <view class="content">
    <!-- 用户信息 -->
    <view class="user-header">
      <view class="user-avatar">
        <van-icon name="user-o" size="32px" color="#1890ff" />
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.name || '未登录'}}</text>
        <text class="user-employee-id">工号：{{userInfo.employeeId || '-'}}</text>
      </view>
    </view>

    <!-- 预约记录标题 -->
    <view class="section-title">
      <text>我的预约</text>
      <text class="record-count">共 {{bookings.length}} 条记录</text>
    </view>

    <!-- 预约列表 -->
    <view wx:if="{{loading}}" class="loading-state">
      <van-loading size="24px" color="#1890ff" />
      <text>加载中...</text>
    </view>

    <view wx:elif="{{bookings.length === 0}}" class="empty-state">
      <van-empty description="暂无预约记录" />
    </view>

    <view wx:else class="bookings-list">
      <view
        class="booking-card"
        wx:for="{{bookings}}"
        wx:key="id"
      >
        <view class="booking-header">
          <view class="booking-date">
            <text class="date-text">{{item.date}}</text>
          </view>
          <view class="booking-status {{statusUtils.getStatusClass(statusUtils.getStatus(item, currentDate, currentTime))}}">
            {{statusUtils.getStatusText(statusUtils.getStatus(item, currentDate, currentTime))}}
          </view>
        </view>

        <view class="booking-body">
          <view class="room-name">{{item.room_name}}</view>
          <view class="booking-subject" wx:if="{{item.subject}}">
            <text class="subject-text">{{item.subject}}</text>
          </view>
          <view class="booking-time">
            <van-icon name="clock-o" size="14px" color="#999" />
            <text>{{item.start_time}} - {{item.end_time}}</text>
          </view>
          <view class="booking-location" wx:if="{{item.room_location}}">
            <van-icon name="location-o" size="14px" color="#999" />
            <text>{{item.room_location}}</text>
          </view>
          <view class="booking-purpose" wx:if="{{item.purpose}}">
            <text class="purpose-label">备注：</text>
            <text>{{item.purpose}}</text>
          </view>
        </view>

        <view class="booking-footer" wx:if="{{statusUtils.canCancel(item, currentDate, currentTime)}}">
          <button
            class="cancel-btn"
            data-id="{{item.id}}"
            catchtap="onCancelBooking"
          >
            取消预约
          </button>
        </view>
      </view>
    </view>
  </view>
</view>