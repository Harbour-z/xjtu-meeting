/* pages/room/room.wxss */

.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  /* 禁止水平滚动 */
  overflow-x: hidden;
  width: 100%;
  box-sizing: border-box;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 24rpx;
  color: #999;
  gap: 16rpx;
}

.content {
  padding: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 会议室信息卡片 */
.room-info-card {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 12rpx;
  padding: 20rpx;
  color: white;
  margin-bottom: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.room-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  /* 文字溢出处理 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.room-equipment {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 6rpx;
  /* 允许换行 */
  flex-wrap: wrap;
}

/* 日期头 */
.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
  width: 100%;
}

.date-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #1890ff;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 时间线容器 */
.timeline-container {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.timeline-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

/* 时间格子 - 每行4个 */
.timeline-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  width: 100%;
}

.time-slot {
  border-radius: 6rpx;
  padding: 10rpx 4rpx;
  text-align: center;
  transition: all 0.2s ease;
  /* 防止内容溢出 */
  min-width: 0;
  overflow: hidden;
}

/* 空闲状态 - 绿色 */
.time-slot-available {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
}

.time-slot-available:active {
  background: #d9f7be;
}

/* 部分占用状态 - 黄色 */
.time-slot-partially_booked {
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
}

.time-slot-partially_booked:active {
  background: #fff1b8;
}

/* 已约满状态 - 红色 */
.time-slot-fully_booked {
  background: #fff2f0;
  border: 2rpx solid #ffccc7;
  opacity: 0.8;
}

/* 已过去的时间段 - 灰色 */
.time-slot-passed {
  background: #f5f5f5 !important;
  border: 2rpx solid #d9d9d9 !important;
  opacity: 0.6;
}

.time-slot-passed .slot-time {
  color: #999 !important;
}

.time-slot-passed .slot-booked-count {
  color: #999 !important;
}

/* 选中状态 - 蓝色高亮 */
.time-slot-selected {
  border: 4rpx solid #1890ff !important;
  box-shadow: 0 0 12rpx rgba(24, 144, 255, 0.3);
  transform: scale(1.02);
}

.time-slot-selected .slot-time {
  color: #1890ff;
  font-weight: 600;
}

.slot-time {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.time-slot-fully_booked .slot-time {
  color: #999;
}

.slot-info {
  margin-top: 2rpx;
}

.slot-booked-count {
  font-size: 16rpx;
  color: #fa8c16;
}

.time-slot-fully_booked .slot-booked-count {
  color: #ff4d4f;
}

/* 图例 */
.legend {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 10rpx 0;
  margin-bottom: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.legend-box {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.legend-box.available {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
}

.legend-box.partially_booked {
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
}

.legend-box.fully_booked {
  background: #fff2f0;
  border: 2rpx solid #ffccc7;
}

/* 手动时间选择区域 */
.manual-time-section {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.time-picker-item {
  flex: 1;
  text-align: center;
}

.time-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.time-picker-value {
  background: #f5f7fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 6rpx;
  padding: 12rpx 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.time-separator {
  font-size: 24rpx;
  color: #999;
  padding-top: 28rpx;
}

.time-tips {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-top: 8rpx;
}

/* 时间冲突提示 */
.time-conflict-warning {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 10rpx;
  padding: 12rpx;
  background: #fff2f0;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #ff4d4f;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.book-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.book-btn.disabled {
  background: #d9d9d9;
  color: #999;
}

.book-btn:active:not(.disabled) {
  background: linear-gradient(135deg, #096dd9, #1890ff);
}

/* 时段详情弹窗 */
.booking-info-popup {
  padding: 32rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.popup-status {
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.popup-status.status-available {
  background: #f6ffed;
  color: #52c41a;
}

.popup-status.status-partially_booked {
  background: #fffbe6;
  color: #fa8c16;
}

.popup-status.status-fully_booked {
  background: #fff2f0;
  color: #ff4d4f;
}

.popup-status.status-passed {
  background: #f5f5f5;
  color: #999;
}

.popup-bookings {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.popup-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.booking-item {
  background: white;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
}

.booking-item:last-child {
  margin-bottom: 0;
}

.booking-item-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 4rpx;
}

.booking-item-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.booking-item-name {
  font-size: 26rpx;
  color: #333;
}

.booking-item-purpose {
  font-size: 24rpx;
  color: #999;
}

.popup-footer {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.popup-close-btn {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.popup-book-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}
