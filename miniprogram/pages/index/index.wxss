/* pages/index/index.wxss */

.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: env(safe-area-inset-bottom);
  /* 禁止水平滚动 */
  overflow-x: hidden;
  width: 100%;
}

/* 校区标签 */
.campus-tabs {
  display: flex;
  background: #ffffff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  /* 确保不溢出 */
  width: 100%;
  box-sizing: border-box;
}

.campus-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #666;
  font-size: 28rpx;
  transition: all 0.3s ease;
  /* 文字不换行但允许缩小 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.campus-tab.active {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: white;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

/* 日期滚动栏 - 独立的水平滚动区域 */
.date-section {
  background: #ffffff;
  padding: 20rpx 0;
  margin-top: 2rpx;
  width: 100%;
  box-sizing: border-box;
}

.date-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 0 16rpx;
  box-sizing: border-box;
  /* 确保水平滚动正常工作 */
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  width: 96rpx;
  height: 100rpx;
  margin: 0 8rpx;
  padding: 12rpx 8rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  transition: all 0.2s ease;
  vertical-align: top;
}

.date-item.active {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

.date-item-day {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.date-item.active .date-item-day {
  color: white;
}

.date-item-week {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.date-item.active .date-item-week {
  color: rgba(255, 255, 255, 0.9);
}

.date-more {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

/* 会议室列表容器 */
.rooms-container {
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  color: #999;
  font-size: 28rpx;
  gap: 16rpx;
}

/* 会议室卡片 */
.rooms-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.room-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}

.room-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  /* 确保不溢出 */
  width: 100%;
}

.room-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  /* 文字溢出处理 */
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status.available {
  background: #f6ffed;
  color: #52c41a;
}

.status.busy {
  background: #fff2f0;
  color: #ff4d4f;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.dot-available {
  background: #52c41a;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.5);
}

.dot-busy {
  background: #ff4d4f;
  box-shadow: 0 0 8rpx rgba(255, 77, 79, 0.5);
}

.room-info {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  /* 文字溢出处理 */
  max-width: 100%;
  overflow: hidden;
}

.info-item text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.earliest-time {
  display: flex;
  flex-wrap: wrap;
  font-size: 26rpx;
  color: #999;
}

.time-value {
  color: #1890ff;
  font-weight: 500;
}

/* 日历弹窗样式覆盖 - 确保日历内容可滚动 */
.van-calendar {
  display: flex;
  flex-direction: column;
  height: auto !important;
  max-height: 85vh;
}

.van-calendar__popup--bottom {
  height: 85vh !important;
}

.van-calendar__body {
  flex: 1;
  max-height: 65vh;
  overflow-y: auto !important;
  -webkit-overflow-scrolling: touch;
}

.van-calendar__footer {
  display: flex;
  justify-content: center;
  padding: 16rpx 32rpx !important;
  flex-shrink: 0;
}

.van-calendar__confirm {
  width: 100% !important;
  margin: 0 !important;
}

/* 确保日历月份可滚动 */
.van-calendar__month {
  display: block;
}

.van-calendar__days {
  display: grid;
}