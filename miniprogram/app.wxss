/* app.wxss - 全局样式 */

/* 设计系统变量 */
page {
  --primary: #1890ff;
  --primary-light: #40a9ff;
  --primary-dark: #096dd9;
  --success: #52c41a;
  --warning: #faad14;
  --danger: #ff4d4f;
  --text: #333333;
  --text-light: #666666;
  --text-muted: #999999;
  --border: #e8e8e8;
  --bg: #f5f7fa;
  --card: #ffffff;
  --radius: 12rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background-color: var(--bg);
  line-height: 1.5;

  /* 禁止页面水平滚动 */
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 所有元素禁止超出屏幕 */
view, text, image, scroll-view {
  box-sizing: border-box;
  max-width: 100vw;
}

/* 文字自动换行 */
text {
  word-wrap: break-word;
  word-break: break-all;
}

/* 通用类 */
.container {
  padding: 24rpx;
}

.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.text-primary { color: var(--primary); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }
.text-muted { color: var(--text-muted); }

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  border: none;
  border-radius: var(--radius);
}

.btn-primary:active {
  background: linear-gradient(135deg, var(--primary-dark), var(--primary));
}

/* 状态标签 */
.status-available {
  background: #f6ffed;
  color: var(--success);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-busy {
  background: #fff2f0;
  color: var(--danger);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* Flex 工具类 */
.flex { display: flex; }
.flex-center { justify-content: center; align-items: center; }
.flex-between { justify-content: space-between; align-items: center; }
.flex-column { flex-direction: column; }
.flex-1 { flex: 1; }

/* 间距工具类 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-24 { padding: 24rpx; }

/* 安全区适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}